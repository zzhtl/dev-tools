{
  "categories": [
    {
      "name": "CPU监控",
      "icon": "🔧",
      "description": "查看CPU使用率、负载、进程占用等",
      "commands": [
        {
          "command": "top",
          "description": "实时监控系统进程和CPU使用情况",
          "keywords": ["cpu", "进程", "监控", "使用率", "负载"],
          "examples": ["top", "top -u username", "top -p pid1,pid2"],
          "tips": "按 1 显示每个CPU核心，按 q 退出"
        },
        {
          "command": "htop",
          "description": "增强版进程监控工具，支持鼠标操作",
          "keywords": ["cpu", "进程", "监控", "增强"],
          "examples": ["htop", "htop -u username", "htop -d 10"],
          "tips": "需要安装: apt install htop"
        },
        {
          "command": "mpstat",
          "description": "查看每个CPU核心的详细统计信息",
          "keywords": ["cpu", "核心", "统计", "多核"],
          "examples": ["mpstat", "mpstat -P ALL", "mpstat 1 5"],
          "tips": "需要安装 sysstat 包"
        },
        {
          "command": "uptime",
          "description": "查看系统运行时间和平均负载",
          "keywords": ["负载", "运行时间", "load"],
          "examples": ["uptime"],
          "tips": "负载值 < CPU核心数表示系统空闲"
        },
        {
          "command": "vmstat",
          "description": "查看虚拟内存、CPU、IO等综合信息",
          "keywords": ["cpu", "内存", "io", "统计"],
          "examples": ["vmstat", "vmstat 1 10", "vmstat -s"],
          "tips": "第一个参数是间隔秒数，第二个是次数"
        },
        {
          "command": "sar -u",
          "description": "查看CPU历史使用统计",
          "keywords": ["cpu", "历史", "统计", "性能"],
          "examples": ["sar -u 1 5", "sar -u -f /var/log/sysstat/sa01"],
          "tips": "需要安装并启动 sysstat 服务"
        }
      ]
    },
    {
      "name": "内存监控",
      "icon": "💾",
      "description": "查看内存使用、缓存、交换分区等",
      "commands": [
        {
          "command": "free",
          "description": "显示系统内存和交换分区使用情况",
          "keywords": ["内存", "memory", "swap", "缓存"],
          "examples": ["free -h", "free -m", "free -g"],
          "tips": "-h 人类可读, -m MB显示, -g GB显示"
        },
        {
          "command": "cat /proc/meminfo",
          "description": "查看详细的内存信息",
          "keywords": ["内存", "详细", "meminfo"],
          "examples": ["cat /proc/meminfo", "cat /proc/meminfo | grep MemTotal"],
          "tips": "显示所有内存相关的详细参数"
        },
        {
          "command": "vmstat -s",
          "description": "以详细列表形式显示内存统计",
          "keywords": ["内存", "统计", "详细"],
          "examples": ["vmstat -s"],
          "tips": "显示内存事件计数器"
        },
        {
          "command": "smem",
          "description": "按进程显示内存占用（含共享内存）",
          "keywords": ["内存", "进程", "共享内存", "pss"],
          "examples": ["smem", "smem -rs pss", "smem -u"],
          "tips": "需要安装: apt install smem"
        },
        {
          "command": "pmap",
          "description": "查看进程的内存映射",
          "keywords": ["内存", "进程", "映射", "虚拟内存"],
          "examples": ["pmap pid", "pmap -x pid"],
          "tips": "-x 显示扩展格式"
        }
      ]
    },
    {
      "name": "磁盘IO",
      "icon": "💿",
      "description": "查看磁盘读写速度、IO等待等",
      "commands": [
        {
          "command": "iostat",
          "description": "显示磁盘IO统计信息",
          "keywords": ["io", "磁盘", "读写", "统计"],
          "examples": ["iostat", "iostat -x 1 5", "iostat -xdm 1"],
          "tips": "-x 显示扩展信息, -d 只显示磁盘, -m MB单位"
        },
        {
          "command": "iotop",
          "description": "实时监控进程的磁盘IO",
          "keywords": ["io", "进程", "实时", "监控"],
          "examples": ["iotop", "iotop -o", "iotop -P"],
          "tips": "需要root权限: sudo iotop"
        },
        {
          "command": "df",
          "description": "查看磁盘空间使用情况",
          "keywords": ["磁盘", "空间", "容量", "使用率"],
          "examples": ["df -h", "df -i", "df -T"],
          "tips": "-h 人类可读, -i 显示inode, -T 显示文件系统类型"
        },
        {
          "command": "du",
          "description": "查看目录或文件占用空间",
          "keywords": ["磁盘", "目录", "文件", "大小"],
          "examples": ["du -sh *", "du -h --max-depth=1", "du -ah | sort -rh | head -20"],
          "tips": "-s 汇总, -h 人类可读"
        },
        {
          "command": "lsblk",
          "description": "列出所有块设备信息",
          "keywords": ["磁盘", "设备", "分区", "块设备"],
          "examples": ["lsblk", "lsblk -f", "lsblk -o NAME,SIZE,TYPE,MOUNTPOINT"],
          "tips": "-f 显示文件系统信息"
        },
        {
          "command": "fdisk -l",
          "description": "查看磁盘分区表详细信息",
          "keywords": ["磁盘", "分区", "详细"],
          "examples": ["fdisk -l", "fdisk -l /dev/sda"],
          "tips": "需要root权限"
        },
        {
          "command": "hdparm -t",
          "description": "测试磁盘读取速度",
          "keywords": ["磁盘", "速度", "测试", "性能"],
          "examples": ["hdparm -t /dev/sda", "hdparm -Tt /dev/sda"],
          "tips": "需要root权限"
        },
        {
          "command": "dd",
          "description": "测试磁盘写入速度",
          "keywords": ["磁盘", "写入", "测试", "速度"],
          "examples": ["dd if=/dev/zero of=test bs=1G count=1 oflag=dsync", "dd if=test of=/dev/null bs=1M"],
          "tips": "测试完后记得删除测试文件"
        }
      ]
    },
    {
      "name": "网络监控",
      "icon": "🌐",
      "description": "查看网络流量、连接、端口等",
      "commands": [
        {
          "command": "ifconfig",
          "description": "查看和配置网络接口",
          "keywords": ["网络", "ip", "网卡", "接口"],
          "examples": ["ifconfig", "ifconfig eth0", "ifconfig -a"],
          "tips": "新系统推荐使用 ip addr"
        },
        {
          "command": "ip",
          "description": "现代化的网络配置命令",
          "keywords": ["网络", "ip", "路由", "配置"],
          "examples": ["ip addr", "ip link", "ip route", "ip neigh"],
          "tips": "ip addr 查看地址, ip route 查看路由"
        },
        {
          "command": "netstat",
          "description": "显示网络连接、路由表、接口统计",
          "keywords": ["网络", "连接", "端口", "监听"],
          "examples": ["netstat -tuln", "netstat -anp", "netstat -s"],
          "tips": "-t TCP, -u UDP, -l 监听, -n 数字显示, -p 显示进程"
        },
        {
          "command": "ss",
          "description": "更快速的socket统计工具（替代netstat）",
          "keywords": ["网络", "socket", "连接", "端口"],
          "examples": ["ss -tuln", "ss -s", "ss -anp"],
          "tips": "比netstat更快，参数类似"
        },
        {
          "command": "lsof -i",
          "description": "查看网络端口占用",
          "keywords": ["端口", "占用", "进程", "监听"],
          "examples": ["lsof -i", "lsof -i :80", "lsof -i -P -n"],
          "tips": "-P 不解析端口名, -n 不解析主机名"
        },
        {
          "command": "iftop",
          "description": "实时监控网络带宽使用",
          "keywords": ["网络", "带宽", "流量", "实时"],
          "examples": ["iftop", "iftop -i eth0", "iftop -n"],
          "tips": "需要root权限"
        },
        {
          "command": "nethogs",
          "description": "按进程显示网络流量",
          "keywords": ["网络", "进程", "流量", "带宽"],
          "examples": ["nethogs", "nethogs eth0"],
          "tips": "需要安装: apt install nethogs"
        },
        {
          "command": "nload",
          "description": "实时显示网络流量图表",
          "keywords": ["网络", "流量", "图表", "监控"],
          "examples": ["nload", "nload eth0"],
          "tips": "需要安装: apt install nload"
        },
        {
          "command": "tcpdump",
          "description": "抓取网络数据包",
          "keywords": ["网络", "抓包", "数据包", "调试"],
          "examples": ["tcpdump -i eth0", "tcpdump -w capture.pcap", "tcpdump port 80"],
          "tips": "需要root权限"
        },
        {
          "command": "ping",
          "description": "测试网络连通性",
          "keywords": ["网络", "连通", "测试", "延迟"],
          "examples": ["ping google.com", "ping -c 4 192.168.1.1", "ping -i 0.5 host"],
          "tips": "-c 指定次数, -i 指定间隔"
        },
        {
          "command": "traceroute",
          "description": "跟踪数据包路由路径",
          "keywords": ["网络", "路由", "跟踪", "路径"],
          "examples": ["traceroute google.com", "traceroute -n host"],
          "tips": "-n 不解析主机名"
        },
        {
          "command": "mtr",
          "description": "结合ping和traceroute的网络诊断工具",
          "keywords": ["网络", "诊断", "路由", "延迟"],
          "examples": ["mtr google.com", "mtr -r host"],
          "tips": "需要安装: apt install mtr"
        },
        {
          "command": "curl",
          "description": "命令行HTTP请求工具",
          "keywords": ["http", "请求", "api", "下载"],
          "examples": ["curl https://api.example.com", "curl -o file.zip url", "curl -X POST -d 'data' url"],
          "tips": "-o 保存文件, -X 指定方法, -d 发送数据"
        },
        {
          "command": "wget",
          "description": "命令行下载工具",
          "keywords": ["下载", "http", "文件"],
          "examples": ["wget url", "wget -c url", "wget -r url"],
          "tips": "-c 断点续传, -r 递归下载"
        }
      ]
    },
    {
