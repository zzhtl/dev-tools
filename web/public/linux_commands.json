        }
      ]
    },
    {
      "name": "进程管理",
      "icon": "⚙️",
      "description": "查看、管理、终止进程",
      "commands": [
        {
          "command": "ps",
          "description": "显示当前进程快照",
          "keywords": ["进程", "查看", "列表"],
          "examples": ["ps aux", "ps -ef", "ps -u username", "ps aux --sort=-%mem | head"],
          "tips": "aux BSD风格, -ef UNIX风格"
        },
        {
          "command": "pgrep",
          "description": "根据名称查找进程ID",
          "keywords": ["进程", "查找", "pid"],
          "examples": ["pgrep nginx", "pgrep -l nginx", "pgrep -u root"],
          "tips": "-l 显示进程名, -u 按用户过滤"
        },
        {
          "command": "pidof",
          "description": "根据程序名获取PID",
          "keywords": ["进程", "pid", "查找"],
          "examples": ["pidof nginx", "pidof -s nginx"],
          "tips": "-s 只返回一个PID"
        },
        {
          "command": "kill",
          "description": "发送信号给进程",
          "keywords": ["进程", "终止", "信号", "杀死"],
          "examples": ["kill pid", "kill -9 pid", "kill -15 pid"],
          "tips": "-9 强制终止, -15 正常终止"
        },
        {
          "command": "killall",
          "description": "根据名称终止所有匹配进程",
          "keywords": ["进程", "终止", "批量"],
          "examples": ["killall nginx", "killall -9 nginx"],
          "tips": "会终止所有同名进程"
        },
        {
          "command": "pkill",
          "description": "根据模式匹配终止进程",
          "keywords": ["进程", "终止", "模式"],
          "examples": ["pkill nginx", "pkill -u username", "pkill -f 'python script'"],
          "tips": "-f 匹配完整命令行"
        },
        {
          "command": "nice",
          "description": "以指定优先级运行程序",
          "keywords": ["进程", "优先级", "nice"],
          "examples": ["nice -n 10 command", "nice -n -5 command"],
          "tips": "值范围-20(最高)到19(最低)"
        },
        {
          "command": "renice",
          "description": "修改运行中进程的优先级",
          "keywords": ["进程", "优先级", "修改"],
          "examples": ["renice 10 -p pid", "renice -5 -p pid"],
          "tips": "需要root权限降低nice值"
        },
        {
          "command": "nohup",
          "description": "使命令在后台运行不受终端影响",
          "keywords": ["后台", "运行", "守护"],
          "examples": ["nohup command &", "nohup ./script.sh > output.log 2>&1 &"],
          "tips": "输出默认保存到 nohup.out"
        },
        {
          "command": "bg/fg",
          "description": "将任务放到后台/前台执行",
          "keywords": ["后台", "前台", "任务"],
          "examples": ["bg %1", "fg %1", "jobs"],
          "tips": "Ctrl+Z 暂停当前任务"
        }
      ]
    },
    {
